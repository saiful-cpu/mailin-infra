## Postfix Integration — Standalone MTA
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_facts['date_time'].iso8601 }}

init_config:
  postfix_user: postfix
  postqueue_path: /usr/sbin/postqueue

instances:
  - directory: {{ postfix_queue_dir }}
    queues:
      - incoming
      - active
      - deferred
      - bounce
      - corrupt
      - hold
    tags:
      - env:{{ dd_env }}
      - role:{{ server_role }}
      - host:{{ ansible_facts['hostname'] }}
      - service:postfix

logs:
  - type: file
    path: {{ postfix_log_path }}
    source: postfix
    service: postfix
    tags:
      - env:{{ dd_env }}
      - role:{{ server_role }}
      - host:{{ ansible_facts['hostname'] }}
      - service:postfix
