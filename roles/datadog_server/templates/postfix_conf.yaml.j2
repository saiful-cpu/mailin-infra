## Postfix Integration — Standalone MTA
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_facts['date_time'].iso8601 }}

init_config:

instances:
  - directory: {{ postfix_queue_dir }}
    queues:
      - active
      - deferred
      - hold
      - incoming
      - maildrop
    tags:
      - env:{{ dd_env }}
      - role:{{ server_role }}
      - host:{{ ansible_facts['hostname'] }}
      - service:postfix

logs:
  - type: journald
    source: postfix
    service: postfix
    include_units:
      - postfix.service
      - postfix@.service
