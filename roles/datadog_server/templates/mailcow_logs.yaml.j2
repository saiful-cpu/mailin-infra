## Mailcow Container Log Enrichment
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_facts['date_time'].iso8601 }}
##
## Container log collection is driven by container_collect_all: true in datadog.yaml.
## This file remaps source/service per Mailcow container using processing rules.

logs:
  - type: docker
    source: postfix
    service: mailcow-postfix
    log_processing_rules:
      - type: include_at_match
        name: include_mailcow_postfix
        pattern: "postfix-mailcow"
    tags: [env:{{ dd_env }}, role:{{ server_role }}, host:{{ ansible_facts['hostname'] }}, mail_component:mta]

  - type: docker
    source: dovecot
    service: mailcow-dovecot
    log_processing_rules:
      - type: include_at_match
        name: include_mailcow_dovecot
        pattern: "dovecot-mailcow"
    tags: [env:{{ dd_env }}, role:{{ server_role }}, host:{{ ansible_facts['hostname'] }}, mail_component:imap]

  - type: docker
    source: rspamd
    service: mailcow-rspamd
    log_processing_rules:
      - type: include_at_match
        name: include_mailcow_rspamd
        pattern: "rspamd-mailcow"
    tags: [env:{{ dd_env }}, role:{{ server_role }}, host:{{ ansible_facts['hostname'] }}, mail_component:antispam]

  - type: docker
    source: nginx
    service: mailcow-nginx
    log_processing_rules:
      - type: include_at_match
        name: include_mailcow_nginx
        pattern: "nginx-mailcow"
    tags: [env:{{ dd_env }}, role:{{ server_role }}, host:{{ ansible_facts['hostname'] }}, mail_component:proxy]

  - type: docker
    source: mysql
    service: mailcow-mysql
    log_processing_rules:
      - type: include_at_match
        name: include_mailcow_mysql
        pattern: "mysql-mailcow"
    tags: [env:{{ dd_env }}, role:{{ server_role }}, host:{{ ansible_facts['hostname'] }}, mail_component:database]
