## Redis Integration
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_facts['date_time'].iso8601 }}

init_config:

instances:
  - min_collection_interval: {{ dd_min_collection_interval }}
    host: {{ redis_host }}
    port: {{ redis_port }}
{% if redis_password | length > 0 %}
    password: {{ redis_password }}
{% endif %}
    collect_client_metrics: true
    command_stats: false
    slowlog: false
    socket_timeout: 5
    warn_on_missing_keys: true
    tags:
      - env:{{ dd_env }}
      - role:{{ server_role }}
      - host:{{ ansible_facts['hostname'] }}
      - service:redis
