      - qmgr

  - name: clamd
    min_collection_interval: {{ dd_min_collection_interval }}
    search_string:
      - "clamd.sh"

  - name: dovecot
    min_collection_interval: {{ dd_min_collection_interval }}
    search_string:
      - dovecot
      - imap

  - name: rspamd
