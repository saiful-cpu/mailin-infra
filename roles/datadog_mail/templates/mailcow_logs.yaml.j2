## Mailcow Docker Container Log Collection
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_facts['date_time'].iso8601 }}
##
## Filters use Docker Compose service labels (com.docker.compose.service)
## rather than image names, which vary across Mailcow versions.

logs:
  - type: docker
    source: postfix
    service: mailcow-postfix
    log_processing_rules:
      - type: include_at_match
        name: postfix_logs
        pattern: "postfix"
    label:
      com.docker.compose.service: postfix-mailcow
    tags:
      - mail_component:mta
      - mail_server:{{ ansible_facts['hostname'] }}
      - mail_type:{{ mail_type }}

  - type: docker
    source: dovecot
    service: mailcow-dovecot
