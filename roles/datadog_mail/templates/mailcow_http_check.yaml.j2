## HTTP Checks — Mailcow Services
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_facts['date_time'].iso8601 }}

init_config:

instances:
  - name: mailcow_webui
    url: https://{{ mailcow_hostname }}/
    method: GET
    timeout: 10
    tls_verify: false
    tags:
      - service:mailcow
      - component:webui
      - mail_server:{{ ansible_facts['hostname'] }}
      - mail_type:{{ mail_type }}

  - name: mailcow_api
    url: https://{{ mailcow_hostname }}/api/v1/get/status/containers
    method: GET
    timeout: 10
    tls_verify: false
    tags:
      - service:mailcow
      - component:api
      - mail_server:{{ ansible_facts['hostname'] }}
      - mail_type:{{ mail_type }}

  - name: mailcow_sogo
    url: https://{{ mailcow_hostname }}/SOGo/
    method: GET
    timeout: 10
    tls_verify: false
    tags:
      - service:mailcow
      - component:sogo
      - mail_server:{{ ansible_facts['hostname'] }}
      - mail_type:{{ mail_type }}
