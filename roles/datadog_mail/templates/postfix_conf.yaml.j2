## Postfix Integration — Standalone MTA
## Managed by Ansible — do not edit manually
## Generated: {{ ansible_date_time.iso8601 }}

init_config:
  postfix_user: postfix
  postqueue_path: /usr/sbin/postqueue

instances:
  - directory: {{ postfix_queue_dir }}
    queues:
      - incoming
      - active
      - deferred
      - bounce
      - corrupt
      - hold
    tags:
      - mail_mta:postfix
      - mail_server:{{ ansible_hostname }}
      - mail_type:{{ mail_type }}

logs:
  - type: file
    path: {{ postfix_log_path }}
    source: postfix
    service: postfix
    tags:
      - mail_mta:postfix
      - mail_server:{{ ansible_hostname }}
      - mail_type:{{ mail_type }}

  - type: file
    path: {{ postfix_log_path | replace('.log', '.err') | replace('maillog', 'maillog') }}
    source: postfix
    service: postfix
    tags:
      - mail_mta:postfix
      - mail_server:{{ ansible_hostname }}
      - mail_type:{{ mail_type }}
      - log_level:error
