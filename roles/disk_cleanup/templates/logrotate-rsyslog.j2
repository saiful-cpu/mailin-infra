# Managed by Ansible (role: disk_cleanup). Do not edit manually.
# Rotates syslog/kern.log/auth.log when they exceed {{ logrotate_syslog_max_size }},
# regardless of the weekly schedule. Keeps {{ logrotate_syslog_rotate }} rotations.
/var/log/syslog
/var/log/kern.log
/var/log/auth.log
/var/log/mail.info
/var/log/mail.warn
/var/log/mail.err
/var/log/mail.log
/var/log/daemon.log
/var/log/user.log
/var/log/lpr.log
/var/log/cron.log
/var/log/debug
/var/log/messages
{
    size {{ logrotate_syslog_max_size }}
    rotate {{ logrotate_syslog_rotate }}
    missingok
    notifempty
    compress
    delaycompress
    sharedscripts
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}
